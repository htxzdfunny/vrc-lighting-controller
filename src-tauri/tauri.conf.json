{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/tauri-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "VRC Lighting Controller",
  "version": "0.1.0",
  "identifier": "com.vrc-lighting-controller.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "beforeBundleCommand": {
      "script": "node scripts/prepare-runtime-deps.mjs",
      "cwd": ".."
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VRC Lighting Controller",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      },
      {
        "label": "output",
        "title": "VRC Lighting Output",
        "url": "output.html",
        "width": 90,
        "height": 720,
        "resizable": false,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "resources": {
      "resources/runtime/win-x64/spout/*.dll": "",
      "resources/runtime/win-x64/ndi/*.dll": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": false
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "installerHooks": "installer-hooks.nsh"
      }
    }
  }
}
